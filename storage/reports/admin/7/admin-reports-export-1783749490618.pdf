<!doctype html><html><head><meta charset="utf-8" /><title>Admin Reports export</title><style>* { margin: 0; padding: 0; box-sizing: border-box; } body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', sans-serif; color: #1e293b; line-height: 1.6; background: #ffffff; page-break-after: always; } @page { size: A4; margin: 1.25in 0.75in; } header { border-bottom: 3px solid #0f172a; margin-bottom: 30px; padding-bottom: 20px; } h1 { font-size: 32px; font-weight: 700; color: #0f172a; margin-bottom: 8px; } h2 { font-size: 20px; font-weight: 600; color: #0f172a; margin: 30px 0 15px; border-bottom: 1px solid #e2e8f0; padding-bottom: 8px; } p { margin: 8px 0; color: #475569; font-size: 14px; } ul { margin-left: 20px; margin-top: 10px; } li { margin: 5px 0; color: #475569; font-size: 14px; } table { width: 100%; border-collapse: collapse; margin: 15px 0; background: white; } th { background: #f1f5f9; border: 1px solid #cbd5e1; padding: 12px; text-align: left; font-weight: 600; color: #0f172a; font-size: 13px; } td { border: 1px solid #e2e8f0; padding: 10px 12px; font-size: 12px; color: #475569; } tr:nth-child(even) { background: #f8fafc; } .card { border: 1px solid #cbd5e1; border-radius: 8px; padding: 16px; margin: 10px 0; background: #f8fafc; display: inline-block; min-width: 200px; margin-right: 15px; } .card strong { color: #0f172a; display: block; margin-bottom: 5px; font-size: 14px; } .card div { font-size: 18px; font-weight: 700; color: #1e293b; } footer { margin-top: 40px; padding-top: 20px; border-top: 2px solid #e2e8f0; font-size: 11px; color: #64748b; text-align: right; } section { margin-bottom: 30px; page-break-inside: avoid; } </style></head><body><header><h1>Admin Reports export</h1><p>Period: Last 7 Days | Format: PDF</p><p style="font-size:12px;color:#64748b;margin-top:8px;">Generated: 11/07/2026, 11:28:04</p></header><section><h2>Selected reports</h2><ul><li>Users</li></ul></section><section><h2>Summary</
{
  "version": 2,
  "framework": "tanstack-start",
  "outputDirectory": "dist/client",

  "rewrites": [
    {
      "source": "/api/v1/health",
      "destination": "/api/server"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    }
  ],

  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 10,
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}